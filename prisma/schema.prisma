// ============================================================
// LAB TRANSACTIONS
// ============================================================

model LabHdr {
  LhdCode         Int          @id @default(autoincrement())
  LhdVtmCode      Int?
  LhdPrefix       String?
  LhdVchNo        Int
  LhdDate         DateTime
  LhdTime         Int?
  LhdPttCode      Int       
  LhdCDctCode     Int?      
  LhdRByCode      Int?      
  LhdReceiptType  String?
  LhdDiscPer      Float?       @default(0)
  LhdTotalAmt     Float?       @default(0)
  LhdRecvdAmt     Float?       @default(0)
  LhdRfugAmt      Float?       @default(0)
  LhdBalAmt       Float?       @default(0)
  LhdAdvAmt       Float?       @default(0)
  LhdRemark       String?
  LhdVoidFlag     Boolean?     @default(false)
  LhdRecState     Int          @default(1)
  LhdCmpCode      Int          @default(1)
  Patient         PatMast      @relation(fields: [LhdPttCode], references: [PttCode])
  Doctor          DoctMast?    @relation(fields: [LhdCDctCode], references: [DctCode])
  ReferredBy      RefByMast?   @relation(fields: [LhdRByCode], references: [RByCode])
  LabRcpt         LabRcpt[]
  LabRcDctDtl     LabRcDctDtl[]
  LabPymtHdr      LabPymtHdr[]
  LabRefdHdr      LabRefdHdr[]
}

model LabRcpt {
  LrdCode         Int       @id @default(autoincrement())
  LrdLhdCode      Int    
  LrdSrvCode      Int?   
  LrdSno          Int?
  LrdUnit         Float?    @default(1)
  LrdRate         Float?    @default(0)
  LrdAmtBefDisc   Float?    @default(0)
  LrdDiscPer      Float?    @default(0)
  LrdDiscAmt      Float?    @default(0)
  LrdAmtAftDisc   Float?    @default(0)
  LrdRecState     Int       @default(1)
  Header          LabHdr    @relation(fields: [LrdLhdCode], references: [LhdCode])
  Service         ServMast? @relation(fields: [LrdSrvCode], references: [SrvCode])
}

model LabRcDctDtl {
  LddCode         Int       @id @default(autoincrement())
  LddLhdCode      Int    
  LddDctCode      Int?   
  LddSharePer     Float?    @default(0)
  LddRecState     Int       @default(1)
  Header          LabHdr    @relation(fields: [LddLhdCode], references: [LhdCode])
  Doctor          DoctMast? @relation(fields: [LddDctCode], references: [DctCode])
}

model LabPymtHdr {
  LphCode         Int      @id @default(autoincrement())
  LphLhdCode      Int?  
  LphDate         DateTime
  LphAmt          Float?   @default(0)
  LphRecState     Int      @default(1)
  Header          LabHdr?  @relation(fields: [LphLhdCode], references: [LhdCode])
}

model LabRefdHdr {
  LrhCode         Int      @id @default(autoincrement())
  LrhLhdCode      Int?  
  LrhDate         DateTime
  LrhAmt          Float?   @default(0)
  LrhRecState     Int      @default(1)
  Header          LabHdr?  @relation(fields: [LrhLhdCode], references: [LhdCode])
}

// ============================================================
// PHARMACY (MDS) TABLES
// ============================================================

model SubItmGrpMst {
  SigCode       Int          @id @default(autoincrement())
  SigName       String
  SigRecState   Int          @default(1)
  SubItmMast    SubItmMast[]
}

model SubItmMast {
  SimCode       Int          @id @default(autoincrement())
  SimName       String
  SimSigCode    Int?      
  SimRecState   Int          @default(1)
  Group         SubItmGrpMst? @relation(fields: [SimSigCode], references: [SigCode])
  IndrStkDtl    IndrStkDtl[]
  OutdStkDtl    OutdStkDtl[]
  MedPurchDtl   MedPurchDtl[]
  MedSaleDtl    MedSaleDtl[]
}

model PartyGrpMst {
  PgpCode       Int         @id @default(autoincrement())
  PgpName       String
  PgpRecState   Int         @default(1)
  PartyMast     PartyMast[]
}

model PartyMast {
  PryCode        Int         @id @default(autoincrement())
  PryName        String
  PryPgpCode     Int?     
  PryAddr        String?
  PryAraCode     Int?     
  PryTelNo       String?
  PryEmail       String?
  PryRecState    Int         @default(1)
  Group          PartyGrpMst? @relation(fields: [PryPgpCode], references: [PgpCode])
  Area           AreaMast?    @relation(fields: [PryAraCode], references: [AraCode])
  MedPurchHdr    MedPurchHdr[]
}

model PharStkMst {
  PsmCode       Int          @id @default(autoincrement())
  PsmName       String
  PsmRecState   Int          @default(1)
  IndrStkDtl    IndrStkDtl[]
  OutdStkDtl    OutdStkDtl[]
}

model MedPurchHdr {
  PuhCode         Int          @id @default(autoincrement())
  PuhVtmCode      Int?
  PuhPrefix       String?
  PuhVchNo        Int
  PuhDate         DateTime
  PuhTime         Int?
  PuhPrtCode      Int?      
  PuhTotalAmt     Float?       @default(0)
  PuhRecState     Int          @default(1)
  PuhCmpCode      Int          @default(1)
  Party           PartyMast?   @relation(fields: [PuhPrtCode], references: [PryCode])
  Details         MedPurchDtl[]
}

model MedPurchDtl {
  PurICode        Int         @id @default(autoincrement())
  PurCode         Int
  PurSno          Int?
  PurSimCode      Int?
  PurQty          Float?      @default(0)
  PurRate         Float?      @default(0)
  PurAmount       Float?      @default(0)
  PurRecState     Int         @default(1)
  Header          MedPurchHdr @relation(fields: [PurCode], references: [PuhCode])
  Item            SubItmMast? @relation(fields: [PurSimCode], references: [SimCode])
}

model MedSaleHdr {
  SahCode         Int          @id @default(autoincrement())
  SahVtmCode      Int?
  SahPrefix       String?
  SahVchNo        Int
  SahDate         DateTime
  SahTime         Int?
  SahPttCode      Int?      
  SahTotalAmt     Float?       @default(0)
  SahRecState     Int          @default(1)
  SahCmpCode      Int          @default(1)
  Patient         PatMast?     @relation(fields: [SahPttCode], references: [PttCode])
  Details         MedSaleDtl[]
}

model MedSaleDtl {
  SalICode        Int         @id @default(autoincrement())
  SalCode         Int
  SalSno          Int?
  SalSimCode      Int?
  SalQty          Float?      @default(0)
  SalRate         Float?      @default(0)
  SalAmount       Float?      @default(0)
  SalRecState     Int         @default(1)
  Header          MedSaleHdr  @relation(fields: [SalCode], references: [SahCode])
  Item            SubItmMast? @relation(fields: [SalSimCode], references: [SimCode])
}

model IndrStkDtl {
  IsdCode         Int         @id @default(autoincrement())
  IsdSimCode      Int?     
  IsdPsmCode      Int?     
  IsdQty          Float?      @default(0)
  IsdDate         DateTime?
  IsdRecState     Int         @default(1)
  Item            SubItmMast? @relation(fields: [IsdSimCode], references: [SimCode])
  Stock           PharStkMst? @relation(fields: [IsdPsmCode], references: [PsmCode])
}

model OutdStkDtl {
  OsdCode         Int         @id @default(autoincrement())
  OsdSimCode      Int?     
  OsdPsmCode      Int?     
  OsdQty          Float?      @default(0)
  OsdDate         DateTime?
  OsdRecState     Int         @default(1)
  Item            SubItmMast? @relation(fields: [OsdSimCode], references: [SimCode])
  Stock           PharStkMst? @relation(fields: [OsdPsmCode], references: [PsmCode])
}

// ============================================================
// SYNC & LOGGING
// ============================================================

model SyncLog {
  SynCode         Int      @id @default(autoincrement())
  SynTableName    String
  SynRecordId     String
  SynOperation    String
  SynTimestamp    DateTime @default(now())
  SynStatus       String   @default("Pending")
  SynErrorMessage String?
}


model SyncConfig {
  id           Int      @id @default(autoincrement())
  lastSyncTime DateTime
  status       String
}
